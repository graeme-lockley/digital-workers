{
  "name": "digital-workers",
  "version": "1.0.0",
  "description": "A simple AI assistant built with pi-mono libraries and web browsing support",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "start": "pnpm --filter @digital-workers/tui start",
    "dev": "pnpm --filter @digital-workers/tui dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "turbo run test",
    "test:all": "bash scripts/test-all.sh",
    "check:story": "bash scripts/check-story.sh",
    "check:epic": "bash scripts/check-epic.sh",
    "check:specs": "bash scripts/check-specs.sh",
    "check:release-workflow": "bash scripts/check-release-workflow.sh",
    "lint:skills": "bash scripts/lint-skills.sh",
    "lint:commit-msg": "bash scripts/validate-commit-msg.sh",
    "setup:hooks": "bash scripts/setup-git-hooks.sh",
    "validate:kanban": "pnpm lint:skills",
    "validate:kanban:all": "bash scripts/validate-kanban-all.sh"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "pi-web-fetch": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.3",
    "eslint": "^9.26.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.31.1"
  }
}
